{
  "name": "cdf",
  "displayName": "CDF",
  "version": "1.0.0",
  "description": "CDF - Agent 开发工作站，基于自然语言驱动的自动化开发工作流",
  "main": "./out/main/index.js",
  "author": "suntianc",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps && patch-package",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.5",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/canvas": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "jsdom": "^26.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^3.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "deepagents": "^1.10.2",
    "electron-log": "^5.4.4",
    "electron-store": "^8.2.0",
    "fast-xml-parser": "^5.8.0",
    "i18next": "^26.3.1",
    "ignore": "^5.3.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "vaul": "^1.1.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.cdf.app",
    "productName": "CDF",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json",
      "node_modules/jsdom/**/*",
      "node_modules/@mozilla/readability/**/*",
      "node_modules/turndown/**/*",
      "node_modules/ignore/**/*"
    ],
    "asarUnpack": [
      "node_modules/jsdom/**/*",
      "node_modules/@mozilla/readability/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
