          <out type="string" name="todos-data-file" />
        </outs>
      </string-op>
      <shell command="cat">
        <args>
          <arg name="todos-data-file" wrap='"' />
        </args>
        <outs>
          <out type="string" name="todos-data" />
        </outs>
      </shell>
    </then>
  </if>
