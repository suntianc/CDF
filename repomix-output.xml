                  {cmd.name}
                </span>
                <span className="text-xs text-[#888] truncate">
                  {cmd.description}
                </span>
              </div>
              {cmd.args && (
                <span className="text-[11px] font-mono text-[#888] shrink-0">
                  {cmd.args}
                </span>
              )}
            </CommandItem>
          ))}
        </CommandGroup>
      </CommandList>
    </CommandDialog>
  )
}
```

