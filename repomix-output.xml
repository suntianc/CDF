const STATUS_BADGE: Record<string, { label: string; variant: 'outline' | 'secondary' | 'destructive' }> = {
  running: { label: '运行中', variant: 'outline' },
  completed: { label: '已完成', variant: 'secondary' },
  error: { label: '出错', variant: 'destructive' },
