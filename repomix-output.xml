@import "tailwindcss";
@import './base.css';
@import "tw-animate-css";
@import "shadcn/tailwind.css";
@import "@fontsource-variable/geist";

@custom-variant dark (&:is(.dark *));

@theme inline {
  --font-heading: var(--font-sans);
  --font-sans: 'Geist Variable', -apple-system, BlinkMacSystemFont, sans-serif;
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
}

:root {
  /* 带有微弱暖色/中性高级灰的高级白，避免死白眼疲劳 */
  --background: #fbfbfb;
  --foreground: #111111;
  --card: #ffffff;
  --card-foreground: #111111;
  --popover: #ffffff;
  --popover-foreground: #111111;

  --muted: #f4f4f5;
  --muted-foreground: #71717a;

  /* 精致的极细灰色线条色（全局核心） */
  --border: rgba(0, 0, 0, 0.06);
  --input: rgba(0, 0, 0, 0.06);

  /* 侧边栏完美融入主体，采用微弱的层次差 */
  --sidebar: #f5f5f5;
  --sidebar-foreground: #222222;
  --sidebar-border: rgba(0, 0, 0, 0.05);
}

.dark {
  /* 极其深邃的超黑/碳黑体系（类似 Vercel/Linear） */
  --background: #0a0a0a;
  --foreground: #f4f4f5;
  --card: #121212;
  --card-foreground: #f4f4f5;
  --popover: #121212;
  --popover-foreground: #f4f4f5;

  --muted: #1b1b1f;
  --muted-foreground: #a1a1aa;

  --border: rgba(255, 255, 255, 0.08);
  --input: rgba(255, 255, 255, 0.08);

  --sidebar: #0e0e11;
  --sidebar-foreground: #e4e4e7;
  --sidebar-border: rgba(255, 255, 255, 0.05);
}

/* 抛弃原生粗糙阴影，改用细腻的复合层级阴影（Linear 风格） */
.shadow-card {
  box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.02);
}
.shadow-elevated {
  box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.05), 0 2px 8px rgba(0, 0, 0, 0.04), 0 12px 24px -4px rgba(0, 0, 0, 0.02);
}
.shadow-sidebar {
  box-shadow: none; /* 去掉生硬右侧侧边栏阴影，仅靠 border 隔离 */
}

/* 极其重要的打字机无边框滚动条（细节控最爱） */
.no-scrollbar::-webkit-scrollbar {
  display: none;
}
.no-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* Window drag region for macOS hiddenInset title bar */
.window-drag-region {
  -webkit-app-region: drag;
}
.window-drag-region button,
.window-drag-region input,
.window-drag-region a {
  -webkit-app-region: no-drag;
}

html, body, #root {
  height: 100%;
  margin: 0;
}

body {
  font-family: 'Geist Variable', -apple-system, BlinkMacSystemFont, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

@layer base {
  * {
    @apply border-border/80 outline-none;
  }
  body {
    @apply bg-background text-foreground tracking-tight selection:bg-neutral-200 dark:selection:bg-neutral-800;
  }
  html {
    @apply font-sans;
  }
}
